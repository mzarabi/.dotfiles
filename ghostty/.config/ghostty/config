### APPEARANCE ###

# Theme
theme = Catppuccin Mocha

macos-titlebar-style = tabs
window-padding-x = 8
window-padding-y = 4
window-decoration = true
background-opacity = 0.95
background-blur-radius = 10
macos-window-buttons = hidden


### FONT ###
font-family = Monaspace Krypton
font-size = 14


### KEYBINDS ###
keybind = super+shift+h=goto_split:left
keybind = super+shift+j=goto_split:bottom
keybind = super+shift+k=goto_split:up
keybind = super+shift+l=goto_split:right
keybind = super+shift+z=toggle_split_zoom
keybind = global:super+§=toggle_quick_terminal


### EXTRAS ###
mouse-hide-while-typing = true
confirm-close-surface=false
window-save-state = never
maximize = true


### QUICK TERMINAL ###
quick-terminal-size = 100%
quick-terminal-animation-duration = 0

# Word navigation
keybind = opt+arrow_left=text:\x1bb
keybind = opt+arrow_right=text:\x1bf
keybind = opt+backspace=text:\x17

# Line navigation
keybind = cmd+arrow_left=csi:H
keybind = cmd+arrow_right=csi:F
keybind = cmd+backspace=text:\x15